<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="room.RoomBookingView">
        <div class="row d-flex g-0 h-lg-100 bg-white">
            <div class="o_room_booking_main col-lg-8 col-xl-9 position-relative d-flex flex-column h-lg-100 overflow-lg-auto">
                <t t-if="state.scheduleBooking or state.bookingToEdit">
                    <RoomBookingForm bookings="state.bookings" createBooking.bind="scheduleBooking" cancel.bind="resetBookingForm" editBooking.bind="editBooking" bookingName="state.bookingName" bookingToEdit="state.bookingToEdit"/>
                </t>
                <div t-else="" class="o_parking_kiosk d-flex flex-column flex-grow-1 justify-content-between gap-4 p-3 p-lg-5 text-white"
                     t-att-class="state.currentBooking ? 'o_parking_kiosk_occupied' : 'o_parking_kiosk_available'">
                    <!-- Layered ambient background -->
                    <span class="o_parking_orb o_parking_orb_1"/>
                    <span class="o_parking_orb o_parking_orb_2"/>
                    <span class="o_parking_orb o_parking_orb_3"/>
                    <span class="o_parking_kiosk_grid position-absolute top-0 start-0 w-100 h-100"/>
                    <span class="o_parking_kiosk_vignette position-absolute top-0 start-0 w-100 h-100"/>

                    <!-- Top bar: brand + live clock -->
                    <div class="o_parking_topbar position-relative d-flex align-items-center justify-content-between">
                        <div class="o_parking_brand d-flex align-items-center gap-2" aria-label="ParkSmart status">
                            <span class="o_parking_brand_dot" aria-hidden="true"/>
                            <span class="o_parking_brand_name">ParkSmart</span>
                        </div>
                        <div class="o_parking_clock_wrap">
                            <RoomDisplayTime/>
                        </div>
                    </div>

                    <!-- Hero -->
                    <div class="o_parking_hero position-relative d-flex flex-fill flex-column align-items-center justify-content-center gap-4 w-100">
                        <t t-if="!state.currentBooking">
                            <t t-if="state.scheduleBookingQuickCreate">
                                <!-- Quick-book card with glass -->
                                <div class="o_parking_kiosk_card o_ps_kiosk_fade_in text-center">
                                    <div class="o_parking_kiosk_badge o_parking_kiosk_badge_free mx-auto mb-3">
                                        <span class="o_parking_kiosk_badge_dot"/>
                                        Slot Available — <t t-esc="props.name"/>
                                    </div>
                                    <h1 class="o_parking_display mb-2">Park Now</h1>
                                    <p class="o_parking_sub mb-4">Enter your vehicle number and pick a duration</p>
                                    <input t-if="!nextBooking || nextBooking.interval.start > now.plus({minutes: 30})"
                                           t-model.lazy.trim="state.bookingName"
                                           class="form-control bg-white fs-4 o_parking_kiosk_input"
                                           placeholder="Vehicle Number (e.g. KA-01-AB-1234)"
                                           aria-label="Vehicle number"
                                           type="text"
                                           autocomplete="off"/>
                                    <div class="d-flex flex-wrap justify-content-center gap-3 my-4">
                                        <button class="o_parking_kiosk_quick_btn"
                                            t-if="!nextBooking || nextBooking.interval.start > now.plus({minutes: 30})"
                                            t-on-click="() => this.quickCreateBooking(30)">
                                            <span class="o_parking_kiosk_quick_duration">30</span>
                                            <span class="o_parking_kiosk_quick_unit">min</span>
                                        </button>
                                        <div t-else="" class="d-flex flex-column align-items-center gap-2 p-3 fs-6">
                                            <i class="fa fa-warning fa-2x"/>
                                            The next reservation is starting soon.
                                        </div>
                                        <button class="o_parking_kiosk_quick_btn"
                                            t-if="!nextBooking || nextBooking.interval.start > now.plus({minutes: 60})"
                                            t-on-click="() => this.quickCreateBooking(60)">
                                            <span class="o_parking_kiosk_quick_duration">1</span>
                                            <span class="o_parking_kiosk_quick_unit">hour</span>
                                        </button>
                                        <button class="o_parking_kiosk_quick_btn"
                                            t-if="!nextBooking || nextBooking.interval.start > now.plus({minutes: 240})"
                                            t-on-click="() => this.quickCreateBooking(240)">
                                            <span class="o_parking_kiosk_quick_duration">4</span>
                                            <span class="o_parking_kiosk_quick_unit">hours</span>
                                        </button>
                                    </div>
                                    <div t-if="!nextBooking" class="o_parking_or_divider">
                                        <span/><span class="o_parking_or_text">or choose a different time</span><span/>
                                    </div>
                                </div>
                            </t>
                            <t t-else="">
                                <!-- Big AVAILABLE hero -->
                                <div class="o_parking_hero_inner o_ps_kiosk_fade_in d-flex flex-column align-items-center">
                                    <div class="o_parking_kiosk_badge o_parking_kiosk_badge_free mb-3">
                                        <span class="o_parking_kiosk_badge_dot"/>
                                        LIVE · ON DUTY
                                    </div>
                                    <div class="o_parking_slot_stage">
                                        <svg class="o_parking_car_svg" viewBox="0 0 260 140" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
                                            <defs>
                                                <linearGradient id="carGradFree" x1="0" y1="0" x2="1" y2="1">
                                                    <stop offset="0" stop-color="#22C55E"/>
                                                    <stop offset="1" stop-color="#10B981"/>
                                                </linearGradient>
                                            </defs>
                                            <ellipse cx="130" cy="128" rx="92" ry="6" fill="rgba(0,0,0,0.35)"/>
                                            <path d="M30 96 Q45 60 95 58 L170 58 Q215 60 230 92 L236 108 Q238 120 226 120 L34 120 Q22 120 24 108 Z"
                                                  fill="url(#carGradFree)" opacity="0.95"/>
                                            <path d="M78 60 L112 40 L170 40 L198 60 Z" fill="rgba(255,255,255,0.18)" stroke="rgba(255,255,255,0.4)" stroke-width="1"/>
                                            <circle cx="78" cy="120" r="16" fill="#0F172A" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                                            <circle cx="78" cy="120" r="6" fill="#475569"/>
                                            <circle cx="186" cy="120" r="16" fill="#0F172A" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                                            <circle cx="186" cy="120" r="6" fill="#475569"/>
                                            <rect x="222" y="78" width="10" height="6" rx="2" fill="#FBBF24"/>
                                            <rect x="28" y="78" width="10" height="6" rx="2" fill="#F8FAFC"/>
                                        </svg>
                                        <div class="o_parking_slot_code">
                                            <span class="o_parking_slot_label">SLOT</span>
                                            <span class="o_parking_slot_code_value" t-esc="props.name"/>
                                        </div>
                                    </div>
                                    <h1 class="o_parking_display o_parking_display_free mt-4">Available</h1>
                                    <p class="o_parking_sub">Tap to reserve — your vehicle can pull in now.</p>
                                    <div class="o_parking_stat_strip">
                                        <span class="o_parking_stat_pill">
                                            <i class="fa fa-bolt"/> Quick Park: 30m · 1h · 4h
                                        </span>
                                        <span t-if="nextBooking" class="o_parking_stat_pill">
                                            <i class="fa fa-clock-o"/>
                                            Next in <t t-esc="nextBooking.interval.start.toLocaleString({hour: '2-digit', minute: '2-digit'})"/>
                                        </span>
                                        <span t-else="" class="o_parking_stat_pill">
                                            <i class="fa fa-calendar-check-o"/> No upcoming reservations today
                                        </span>
                                    </div>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <!-- OCCUPIED hero -->
                            <div class="o_parking_hero_inner o_ps_kiosk_fade_in d-flex flex-column align-items-center">
                                <div class="o_parking_kiosk_badge o_parking_kiosk_badge_taken mb-3">
                                    <span class="o_parking_kiosk_badge_dot"/>
                                    OCCUPIED NOW
                                </div>
                                <div class="o_parking_slot_stage">
                                    <svg class="o_parking_car_svg" viewBox="0 0 260 140" xmlns="http://www.w3.org/2000/svg">
                                        <defs>
                                            <linearGradient id="carGradTaken" x1="0" y1="0" x2="1" y2="1">
                                                <stop offset="0" stop-color="#F43F5E"/>
                                                <stop offset="1" stop-color="#DC2626"/>
                                            </linearGradient>
                                        </defs>
                                        <ellipse cx="130" cy="128" rx="92" ry="6" fill="rgba(0,0,0,0.35)"/>
                                        <path d="M30 96 Q45 60 95 58 L170 58 Q215 60 230 92 L236 108 Q238 120 226 120 L34 120 Q22 120 24 108 Z"
                                              fill="url(#carGradTaken)" opacity="0.95"/>
                                        <path d="M78 60 L112 40 L170 40 L198 60 Z" fill="rgba(255,255,255,0.18)" stroke="rgba(255,255,255,0.4)" stroke-width="1"/>
                                        <circle cx="78" cy="120" r="16" fill="#0F172A" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                                        <circle cx="78" cy="120" r="6" fill="#475569"/>
                                        <circle cx="186" cy="120" r="16" fill="#0F172A" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                                        <circle cx="186" cy="120" r="6" fill="#475569"/>
                                        <rect x="222" y="78" width="10" height="6" rx="2" fill="#FBBF24"/>
                                        <rect x="28" y="78" width="10" height="6" rx="2" fill="#F8FAFC"/>
                                        <!-- License plate with live slot code -->
                                        <g>
                                            <rect x="100" y="98" width="60" height="16" rx="2" fill="#F8FAFC" stroke="rgba(15,23,42,0.5)" stroke-width="1"/>
                                            <text x="130" y="110" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-weight="800" font-size="11" fill="#0F172A" t-esc="props.name"/>
                                        </g>
                                    </svg>
                                    <div class="o_parking_slot_code" role="img" t-att-aria-label="'Parking slot ' + props.name">
                                        <span class="o_parking_slot_label" aria-hidden="true">SLOT</span>
                                        <span class="o_parking_slot_code_value" t-esc="props.name" aria-hidden="true"/>
                                    </div>
                                </div>
                                <h1 class="o_parking_display o_parking_display_taken mt-4">Occupied</h1>
                                <p class="o_parking_sub" t-out="state.currentBooking.name"/>
                            </div>
                            <RoomBookingRemainingTime endTime="state.currentBooking.interval.end"/>
                        </t>
                        <div class="o_parking_cta_row d-flex flex-column flex-sm-row gap-3 mt-2">
                            <button t-if="state.currentBooking" class="o_parking_btn o_parking_btn_primary" t-on-click="endCurrentBooking">
                                <i class="fa fa-sign-out"/>
                                <span>Check Out</span>
                            </button>
                            <button t-elif="!state.scheduleBookingQuickCreate" class="o_parking_btn o_parking_btn_primary" t-on-click="() => this.state.scheduleBookingQuickCreate = true">
                                <i class="fa fa-bolt"/>
                                <span>Quick Park</span>
                            </button>
                            <button class="o_parking_btn o_parking_btn_ghost" t-on-click="() => this.state.scheduleBooking = true">
                                <i class="fa fa-calendar-plus-o"/>
                                <span>Schedule Slot</span>
                            </button>
                        </div>
                    </div>
                    <div class="o_room_bottom position-relative d-flex gap-3 w-100" t-if="state.scheduleBookingQuickCreate">
                        <button class="o_parking_btn o_parking_btn_discard flex-grow-1" t-on-click="resetBookingForm">
                            <i class="fa fa-times"/>
                            <span>Discard</span>
                        </button>
                    </div>
                    <!-- Watermark footer — avoids the abrupt dark cutoff at the page bottom -->
                    <div class="o_parking_watermark position-relative">
                        <span class="o_parking_watermark_line"/>
                        <span class="o_parking_watermark_text">
                            <i class="fa fa-car"/>
                            <span>ParkSmart</span>
                            <span class="o_parking_watermark_dot">·</span>
                            <span>Enterprise Parking, Reimagined</span>
                        </span>
                        <span class="o_parking_watermark_line"/>
                    </div>
                </div>
            </div>
            <div class="o_room_sidebar col-lg-4 col-xl-3 position-relative border-start bg-100">
                <t t-call="room.RoomBookingSidebar"/>
            </div>
        </div>
    </t>

    <t t-name="room.RoomBookingSidebar">
        <div class="position-lg-absolute top-0 start-0 end-0 bottom-0 d-flex flex-column justify-content-between h-100 p-3 o_parking_sidebar">
            <div class="o_parking_sidebar_head">
                <div class="o_parking_sidebar_slot_row">
                    <h4 class="o_parking_sidebar_slot" t-out="props.name"/>
                    <span t-if="props.isPremium" class="o_parking_sidebar_vip">
                        <i class="fa fa-star"/> VIP
                    </span>
                </div>
                <div t-if="props.officeName" class="o_parking_sidebar_office">
                    <i class="fa fa-map-marker"/>
                    <span t-out="props.officeName"/>
                    <t t-if="props.slotLocation"> · <span t-out="props.slotLocation"/></t>
                </div>
                <div t-if="props.isEvCharger or props.isAccessible" class="o_parking_sidebar_badges">
                    <span t-if="props.isEvCharger" class="o_parking_sidebar_badge o_parking_sidebar_badge_ev">
                        <i class="fa fa-bolt"/> EV Charging
                    </span>
                    <span t-if="props.isAccessible" class="o_parking_sidebar_badge o_parking_sidebar_badge_access">
                        <i class="fa fa-wheelchair"/> Accessible
                    </span>
                </div>
                <div class="mb-2 text-muted small" t-if="props.description" t-out="roomDescription"/>
                <div t-if="props.qrDataUri" class="o_parking_sidebar_qr">
                    <div class="o_parking_sidebar_qr_frame">
                        <img t-att-src="props.qrDataUri" alt="Scan to book this slot on your phone" width="140" height="140"/>
                    </div>
                    <div class="o_parking_sidebar_qr_caption">
                        <div class="o_parking_sidebar_qr_title">Scan to book on your phone</div>
                        <div class="o_parking_sidebar_qr_sub">Point your camera here — the booking page opens on your device.</div>
                    </div>
                </div>
            </div>
            <div t-if="state.bookings.length === 0" class="d-flex justify-content-center flex-column flex-fill py-3 text-center o_parking_sidebar_empty">
                <div class="o_parking_sidebar_empty_icon">
                    <i class="fa fa-calendar-o"/>
                </div>
                <h5>No Reservations</h5>
                <span class="text-muted">This slot is open and ready for your vehicle. Tap <b>Quick Park</b> on the left to reserve it now.</span>
            </div>
            <div t-else="" class="flex-fill pt-1 overflow-auto">
                <!-- Today section is shown even if there are no bookings for this day -->
                <h6 class="mt-3 text-capitalize" t-out="state.currentDate.toRelativeCalendar()"/>
                <div class="list-group">
                    <t t-set="previous_date" t-value="state.currentDate"/>
                    <t t-foreach="state.bookings" t-as="booking" t-key="booking.id">
                        <t t-if="booking.interval.start.startOf('day') > previous_date">
                            <div t-if="booking_first" class="text-center text-muted">
                                No Bookings for Today
                            </div>
                            <h6 class="mt-4 mb-2" t-out="booking.interval.start.toLocaleString(dateFormat)"/>
                            <t t-set="previous_date" t-value="booking.interval.start.startOf('day')"/>
                        </t>
                        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start cursor-pointer"
                            t-att-class="state.bookingToEdit?.id === booking.id ? 'active' : ''"
                            t-on-click="() => state.bookingToEdit = {...booking}">
                            <div class="text-break">
                                <div class="d-flex align-items-center">
                                    <span t-out="booking.interval.start.toLocaleString(timeFormat)"/>
                                    <i class="oi oi-arrow-right mx-1 smaller text-muted"/>
                                    <span t-out="booking.interval.end.toLocaleString(timeFormat)"/>
                                </div>
                                <div class="smaller" t-out="booking.name"/>
                            </div>
                            <button class="btn btn-link btn-dark me-n3 mt-n2 p-3 lh-1 smaller" t-on-click.stop="() => this.deleteBooking(booking.id)">
                                <i class="fa fa-trash"/>
                            </button>
                        </div>
                    </t>
                </div>
            </div>
            <div t-if="state.showInstallPwaButton" class="d-flex justify-content-center bg-200 mx-n3 mb-n3 p-2">
                <button class="btn btn-primary" t-on-click="installPwa">Install Application</button>
                <button class="btn btn-link position-absolute end-0" t-on-click="() => state.showInstallPwaButton = false">
                    <i class="oi oi-close"/>
                </button>
            </div>
        </div>
    </t>
</templates>
