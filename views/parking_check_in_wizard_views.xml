<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_parking_check_in_wizard_form" model="ir.ui.view">
        <field name="name">parking.check.in.wizard.form</field>
        <field name="model">parking.check.in.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Early Check-In">
                <sheet>
                    <div class="oe_title">
                        <h2>
                            <i class="fa fa-exclamation-triangle text-warning me-2"/>Early Check-In
                        </h2>
                    </div>
                    <field name="message" nolabel="1" readonly="1"/>
                    <field name="booking_ids" invisible="1"/>
                    <field name="minutes_early" invisible="1"/>
                    <field name="first_start" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm Check-In" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
